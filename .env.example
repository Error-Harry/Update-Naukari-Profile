# ---- required ----
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=replace-me-with-a-long-random-string
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace--a-fernet-key

# ---- service email (outbound notifications) ----
SMTP_EMAIL=your_service_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ---- optional ----
APP_BASE_URL=http://localhost:8000
PLAYWRIGHT_HEADED=true
# Max parallel Playwright browsers per host. Each ~300-500 MB RSS.
# Default: 2. Raise on bigger boxes, lower on 1 vCPU / 1 GB instances.
BROWSER_CONCURRENCY=2
